# Copy this file to ".env.local" (git-ignored) and fill in your key.
#
# PokeWallet API key (required for card search): https://www.pokewallet.io
# Free keys allow 100 requests/hour and 1,000/day.
VITE_POKEWALLET_API_KEY=

# Optional. Defaults to the public API when unset.
# VITE_POKEWALLET_BASE_URL=https://api.pokewallet.io
